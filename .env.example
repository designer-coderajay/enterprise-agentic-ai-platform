# ── LLM Providers ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── LangSmith / Langfuse Observability ──────────────────────────
LANGSMITH_API_KEY=ls__...
LANGSMITH_PROJECT=enterprise-agentic-ai
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/agentic_ai
POSTGRES_USER=agentic_user
POSTGRES_PASSWORD=secret
POSTGRES_DB=agentic_ai

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Qdrant Vector DB ─────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=enterprise_knowledge

# ── Auth ────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── MCP Servers ──────────────────────────────────────────────────
POSTGRES_MCP_PORT=8001
DOCUMENT_MCP_PORT=8002
NOTIFICATION_MCP_PORT=8003

# ── External MCP ────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...
NOTION_TOKEN=secret_...
SLACK_BOT_TOKEN=xoxb-...
EXA_API_KEY=...

# ── S3 Storage ───────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=ap-south-1
S3_BUCKET=enterprise-ai-docs

# ── App Settings ─────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
MAX_AGENT_ITERATIONS=10
